<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/paymentActivityTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pagamento Monero"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/paymentAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Importo da pagare: 0.00 XMR"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/qrCodeImage"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_marginTop="16dp"
            android:adjustViewBounds="true"
            android:background="#FFFFFFFF"
            android:contentDescription="QR Code indirizzo Monero"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Indirizzo Monero"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/moneroAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#11000000"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:text="Generazione indirizzo..."
            android:textIsSelectable="true"
            android:textSize="12sp" />

        <Button
            android:id="@+id/paymentActivityCopyAddressButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:text="Copia indirizzo" />

        <ProgressBar
            android:id="@+id/paymentActivityProgress"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/paymentStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="In attesa di pagamento..."
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/paymentActivityOpenWalletButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:enabled="false"
            android:text="Apri wallet Monero" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Annulla" />
    </LinearLayout>
</ScrollView>
