{
  "name": "myzubster-backend",
  "version": "1.0.0",
  "description": "MyZubster Backend con Fee Decentralizzata",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "echo \"No tests configured\" && exit 0",
