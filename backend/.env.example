# =============================================
# MYZUBSTER - ENVIRONMENT VARIABLES (ESEMPIO)
# =============================================
# 📌 Copia questo file come .env e compila con i tuoi dati
# ⚠️ NON caricare mai il file .env su GitHub!

# ---- Server ----
PORT=3000
NODE_ENV=production
FRONTEND_URL=http://localhost:3001

# ---- Database ----
DATABASE_URL=postgresql://postgres:password@postgres:5432/myzubster
DATABASE_SSL=false

# ---- Redis (opzionale) ----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =============================================
# MONERO
# =============================================

# Rete: mainnet, testnet, stagenet
MONERO_NETWORK=testnet

# URL del wallet RPC
# Per Docker: usa host.docker.internal
# Per locale: usa localhost
MONERO_RPC_URL=http://host.docker.internal:18083

# Password del wallet Monero (se protetto)
MONERO_WALLET_PASSWORD=your_wallet_password

# Indirizzo principale del wallet (ottenibile con get_address)
MONERO_WALLET_ADDRESS=your_monero_address

# Numero minimo di conferme prima di considerare un pagamento valido
# Consigliato: 10 per mainnet, 0 per testnet
MONERO_MIN_CONFIRMATIONS=10

# =============================================
# SECURITY
# =============================================

# Chiave segreta per JWT (cambia con una stringa casuale lunga)
JWT_SECRET=your_jwt_secret_key_here_change_me
JWT_EXPIRES_IN=7d

# Salt per bcrypt (numero di round di hashing)
BCRYPT_SALT=10

# =============================================
# LOGGING
# =============================================

LOG_LEVEL=info
LOG_FILE=logs/app.log

# ---- Database test (per i test) ----
TEST_DATABASE_URL=postgresql://postgres:password@postgres:5432/myzubster_test